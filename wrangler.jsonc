{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "hdszf",
  "compatibility_date": "2026-07-08",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "headers": {
      "/css/*": {
        "Cache-Control": "public, max-age=300"
      },
      "/js/*": {
        "Cache-Control": "public, max-age=300"
      }
    }
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
